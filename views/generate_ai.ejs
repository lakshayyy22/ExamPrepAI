<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Generate AI Practice | ExamPrep AI</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link rel="stylesheet" href="/css/generate_ai.css">
</head>

<body>

<nav class="navbar">
    <div class="logo">
        <i class="fa-solid fa-graduation-cap"></i>
        <span>ExamPrep AI</span>
    </div>

    <div class="nav-right">
        <a href="/dashboard" class="btn-outline">
            <i class="fa-solid fa-arrow-left"></i> Dashboard
        </a>
        <a href="/logout" class="btn-outline">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
    </div>
</nav>

<section class="hero">
    <h1>Generate AI Practice Questions</h1>
    <p>Select subject and exam type to generate your custom practice set</p>
</section>

<section class="form-section">
    <div class="card">

        <form action="/generated-paper" method="POST" id="generateForm">

            <div class="form-group">
                <label for="subject">
                    <i class="fa-solid fa-book"></i>
                    Subject
                </label>
                <select name="subject" id="subject" required>
                    <option value="">-- Select Subject --</option>
                    <option value="OS">Operating Systems</option>
                    <option value="DBMS">DBMS</option>
                    <option value="CN">Computer Networks</option>
                    <option value="SL">Scripting Languages</option>
                    <option value="AISC">AI and Computing</option>
                </select>
            </div>

            <div class="form-group">
                <label for="exam_type">
                    <i class="fa-solid fa-file-pen"></i>
                    Exam Type
                </label>
                <select name="exam_type" id="exam_type" required>
                    <option value="">-- Select Exam Type --</option>
                    <option value="Mid Sem 1">Mid Sem 1</option>
                    <option value="Mid Sem 2">Mid Sem 2</option>
                    <option value="End Sem">End Sem</option>
                </select>
            </div>

            <button type="submit" class="generate-btn">
                <i class="fa-solid fa-wand-magic-sparkles"></i>
                Generate Questions
            </button>

        </form>

    </div>
</section>

<script>
const form = document.getElementById("generateForm");
const button = document.querySelector(".generate-btn");

form.addEventListener("submit", () => {
    button.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Generating...';
    button.disabled = true;
});
</script>

</body>
</html>