<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>ExamPrep AI</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link rel="stylesheet" href="/css/index_style.css">
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar">
    <div class="logo">
        <i class="fa-solid fa-graduation-cap"></i>
        ExamPrep AI
    </div>

    <div class="auth-buttons">
        <a href="/login" class="btn-outline">Login</a>
        <a href="/signup" class="btn-primary">Sign Up</a>
    </div>
</nav>

<!-- HERO -->
<section class="hero">
    <div class="hero-left">
        <h1>AI-Powered <span>Exam Preparation</span></h1>
        <p>
            Access previous year papers, generate intelligent practice tests,
            and prepare smarter with AI-driven tools.
        </p>

        <div class="hero-buttons">
            <a href="/signup" class="btn-primary big">
                <i class="fa-solid fa-rocket"></i> Get Started
            </a>
            <a href="/login" class="btn-secondary big">
                <i class="fa-solid fa-right-to-bracket"></i> Login
            </a>
        </div>
    </div>

    <div class="hero-right">
        <div class="floating-card">
            <i class="fa-solid fa-file-lines"></i>
            <h3>Past Papers</h3>
            <p>Browse by subject & year</p>
        </div>

        <div class="floating-card">
            <i class="fa-solid fa-robot"></i>
            <h3>AI Practice</h3>
            <p>Generate smart exam sets</p>
        </div>

        <div class="floating-card">
            <i class="fa-solid fa-bolt"></i>
            <h3>Instant Access</h3>
            <p>Download anytime</p>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="features">
    <h2>Why Choose ExamPrep AI?</h2>

    <div class="feature-grid">

        <div class="feature-card">
            <i class="fa-solid fa-brain"></i>
            <h3>Smart Generation</h3>
            <p>AI creates realistic practice papers based on patterns.</p>
        </div>

        <div class="feature-card">
            <i class="fa-solid fa-folder-open"></i>
            <h3>Organized Library</h3>
            <p>Access and manage all your uploaded papers easily.</p>
        </div>

        <div class="feature-card">
            <i class="fa-solid fa-shield-halved"></i>
            <h3>Secure & Reliable</h3>
            <p>Your data stays protected with secure authentication.</p>
        </div>

    </div>
</section>

<footer>
    <p>© 2026 ExamPrep AI. Built with ❤️ for students.</p>
</footer>

</body>
</html>