<!DOCTYPE html>
<html>
<head>
  <title>ExamPrep AI - Papers</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="css/papers.css">
</head>
<body>

  <!-- NAVBAR -->
<nav class="navbar">
    <div class="logo">
        <i class="fa-solid fa-graduation-cap"></i>
        <span>ExamPrep AI</span>
    </div>

    <div class="nav-right">
        <a href="/dashboard" class="btn-outline">
            <i class="fa-solid fa-arrow-left"></i> Dashboard
        </a>
        <a href="/logout" class="btn-outline">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
    </div>
</nav>

<div id="RejectedPopup" class="toast hidden">
    ✖ Paper Removed. Kindly refresh.
</div>

  <!-- FILTER SECTION -->
  <section class="filter-section">
    <h1>Browse Question Papers</h1>

    <form action="/papers" method="GET" class="filter-form">

      <div class="form-group">
        <label>Subject</label>
        <select name="subject" required>
          <option value="">Select Subject</option>
          <option value="kjkh">kjkh</option>
          <option value="DBMS">DBMS</option>
          <option value="os">Operating Systems</option>
          <option value="cn">Computer Networks</option>
        </select>
      </div>

      <div class="form-group">
        <label>Exam Type</label>
        <select name="exam_type" required>
          <option value="">Select Exam</option>
          <option value="Mid Sem">sessional</option>
          <option value="End Sem">End Semester</option>
          <option value="quiz">Quiz</option>
        </select>
      </div>

      <button type="submit" class="btn-primary">Search Papers</button>
    </form>
  </section>

  <!-- PAPERS GRID -->
  <section class="papers-container">
    <% if(!papers||papers.length===0){%>
      <div class = "empty-state">
        <h3>No papers found</h3>
        <p>Try changing filters</p>
      </div>
    <%}else{%>
      <% papers.forEach(paper => {%>
      <div class="paper-card" id="paper-<%= paper.id %>" >
        <h3><%=paper.year%></h3>
        <p>Subject: <%=paper.subject%></p>
        <p>Exam: <%=paper.exam_type%></p>
        <div class="card-buttons">
          <button onclick = "viewPaper(<%= paper.id %>)" class="btn-outline">View</button>
        </div>
      </div>
    <%})%>
    <%}%>
  </section>
<script>
  const msg = "<%= msg %>";

  function showPopup(id, paperId) {
    const p = document.getElementById(id);
    window.history.replaceState({}, document.title, "/papers");
    p.classList.remove("hidden");
    document.getElementById(`paper-${paperId}`).remove();
    setTimeout(() => {
      p.classList.add("hidden");
    }, 2000);
  }

  async function viewPaper(id){
    const res = await fetch(`/paper/${id}`);
    const data = await res.json();
    if(!data.success){
      showPopup("RejectedPopup", id);
      return;
    }
    window.open(`/show/${id}`,"_blank");
  }
</script>
</body>
</html>